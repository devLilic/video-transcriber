APP_ENV=production

APP_FEATURE_I18N=true
APP_FEATURE_AUTO_UPDATE=true
APP_FEATURE_APP_PROTECTION=true
APP_FEATURE_LICENSING=true
APP_FEATURE_DATABASE=false
APP_FEATURE_LOGGING=true

APP_I18N_ENABLED=true
APP_I18N_DEFAULT_LANGUAGE=ro
APP_I18N_SUPPORTED_LANGUAGES=en,ro,ru
APP_I18N_NAMESPACES=common,settings,updater,errors,licensing

APP_UPDATE_ENABLED=true
APP_UPDATE_CHANNEL=latest
APP_UPDATE_AUTO_CHECK=true
APP_UPDATE_AUTO_DOWNLOAD=false
APP_UPDATE_ALLOW_PRERELEASE=false
APP_UPDATE_PROVIDER=github
APP_UPDATE_OWNER=YOUR_GITHUB_OWNER
APP_UPDATE_REPO=YOUR_RELEASE_REPO
APP_UPDATE_VISIBILITY=private

APP_APP_PROTECTION_ENABLED=true
APP_APP_PROTECTION_PROFILE=commercial
APP_APP_PROTECTION_ALLOW_DEVTOOLS=false

APP_LICENSING_ENABLED=true
APP_LICENSING_PROVIDER=http
APP_LICENSING_API_BASE_URL=https://api.example.com
APP_LICENSING_PUBLIC_KEY=
APP_LICENSING_DEVICE_BINDING=true
APP_LICENSING_ENFORCE_MACHINE_MATCH=true
APP_LICENSING_ALLOW_GRACE_ON_MISMATCH=false
APP_LICENSING_GRACE_PERIOD_DAYS=7
APP_LICENSING_HEARTBEAT_INTERVAL_MS=21600000
APP_LICENSING_DEGRADED_MODE=readonly
APP_LICENSING_TIMEOUT_MS=5000
APP_LICENSING_ENDPOINT_STATUS=/licenses/status
APP_LICENSING_ENDPOINT_ACTIVATE=/licenses/activate
APP_LICENSING_ENDPOINT_VALIDATE=/licenses/validate
APP_LICENSING_ENDPOINT_HEARTBEAT=/licenses/heartbeat
APP_LICENSING_ENDPOINT_ENTITLEMENTS=/licenses/entitlements

APP_LOGGING_ENABLED=true
APP_LOG_LEVEL=info