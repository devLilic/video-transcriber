{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "md.devlilic.video-transcriber",
  "asar": true,
  "asarUnpack": [
    "node_modules/ffmpeg-static/**",
    "node_modules/ffprobe-static/**"
  ],
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist-electron",
    "dist"
  ],
  "extraResources": [
    {
      "from": "resources/media-tools/win-x64",
      "to": "media-tools/win-x64"
    },
    {
      "from": "resources/whisper/bin/win-x64",
      "to": "whisper/bin/win-x64"
    },
    {
      "from": "resources/whisper/models",
      "to": "whisper/models"
    }
  ],
  "extraMetadata": {
    "main": "dist-electron/main/index.js"
  },
  "mac": {
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "target": [
      "dmg",
      "zip"
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "publish": [
    {
      "provider": "github",
      "owner": "devLilic",
      "repo": "video-transcriber",
      "releaseType": "release"
    }
  ]
}
